import java.util.Scanner;

public class ArraySum2D {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        // Read dimensions
        int R = sc.nextInt();
        int C = sc.nextInt();

        int totalSum = 0;

        // Read the 2D array and calculate sum
        for (int i = 0; i < R; i++) {
            for (int j = 0; j < C; j++) {
                int num = sc.nextInt();
                totalSum += num;
            }
        }

        // Print the result
        System.out.println(totalSum);

        sc.close();
    }
}
