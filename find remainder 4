import java.util.Scanner;

public class RemainderCalculator {
    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        // Read two integers
        int a = scanner.nextInt();
        int b = scanner.nextInt();

        // Calculate remainder
        int remainder = a % b;

        // Print remainder
        System.out.println(remainder);

        scanner.close();
    }
}
